          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "(sum(reproducibility_columns_complete{exam_type=~\"mp|mm|npu\"}) / sum(reproducibility_columns_total{exam_type=~\"mp|mm|npu\"})) * 100",
          "legendFormat": "Overall Coverage %",
          "refId": "A"
