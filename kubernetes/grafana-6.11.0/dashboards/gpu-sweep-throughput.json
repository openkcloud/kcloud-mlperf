{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "GPU Sweep throughput, latency, and error metrics derived from Loki structured logs.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (gpu_type) (rate({job=\"etri-llm-backend\"} |= \"GPU_SWEEP_CELL_COMPLETED\" | json | __error__=\"\" [5m]))",
          "legendFormat": "{{gpu_type}}",
          "refId": "A"
        }
      ],
      "title": "Cell Completion Rate (cells/hour)",
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "alias": "cells/hour",
            "binary": { "left": "Value", "operator": "*", "right": "3600" },
            "mode": "binary",
            "reduce": { "reducer": "sum" }
          }
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["p95", "mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "quantile_over_time(0.95, {job=\"etri-llm-backend\"} |= \"GPU_SWEEP_CELL_COMPLETED\" | json | __error__=\"\" | unwrap duration_seconds [10m])",
          "legendFormat": "p95 wall time",
          "refId": "A"
        }
      ],
      "title": "p95 Cell Wall Time (seconds)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum (rate({job=\"etri-llm-backend\"} |= \"OperatorRaceFailed\" | json | __error__=\"\" [5m]))",
          "legendFormat": "OperatorRaceFailed rate",
          "refId": "A"
        }
      ],
      "title": "OperatorRaceFailed Rate (per second)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["gpu-sweep", "etri", "llm"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "GPU Sweep Throughput",
  "uid": "gpu-sweep-throughput",
  "version": 1
}
