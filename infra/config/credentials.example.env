# Sample credentials file. Copy to `.env` (gitignored) and fill in real values.
# DO NOT commit real values. DO NOT echo these in scripts.
#
# Loading: scripts/common.sh sources `.env` if present, then exports the vars.
# Variables are referenced by name from numbered scripts; never inlined.

# --- Cluster SSH ---
SUDO_PASS=                     # node sudo password (provisioned during cluster install; never commit a real value)
ANSIBLE_VAULT_PASS=             # if you encrypt kubespray inventory with ansible-vault

# --- Container registry ---
DOCKERHUB_USER=jungwooshim
DOCKERHUB_TOKEN=                # dckr_pat_... ; rotate via hub.docker.com/settings/security

# --- HuggingFace (model downloads) ---
HF_TOKEN=                       # hf_... ; from https://huggingface.co/settings/tokens
HF_HOME=/mnt/models/.cache/hf   # cache lives on shared NFS

# --- GitHub (PR / release automation) ---
GH_TOKEN=                       # ghp_... ; minimum scope: repo, workflow

# --- Furiosa NPU runtime ---
FURIOSA_API_KEY=                # set if Furiosa Suite needs licensed access
FURIOSA_MODEL_REPO=             # private model registry override

# --- Web UI overrides ---
LLM_NS=llm-evaluation
VITE_APP_API_BASE_URL=http://10.254.177.41:30980/api

# --- Benchmark behavior toggles ---
GPU_SWEEP_ENABLED=false         # default OFF in prod
GPU_SWEEP_QUIET_WINDOW_START=10 # KST hour; pauses sweep during the window
GPU_SWEEP_QUIET_WINDOW_END=18
GPU_SWEEP_MIN_STAGGER_SECONDS=60
