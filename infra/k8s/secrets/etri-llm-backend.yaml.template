# etri-llm-backend application secret template.
#
# Mirrors the helm chart pattern at:
#   kubernetes/app-chart/templates/etri-llm-backend/secret.yaml
# but with all sensitive values replaced by envsubst placeholders.
#
# Apply via envsubst after sourcing .env:
#   source config/.env
#   envsubst < k8s/secrets/etri-llm-backend.yaml.template | kubectl apply -f -
#
# Required env vars (all must be set in config/.env / secret store):
#   DATABASE_HOST     — Postgres service hostname
#   DATABASE_PORT     — Postgres service port (default: 5432)
#   DATABASE_USER     — Postgres username
#   DATABASE_PASSWORD — Postgres password
#   DATABASE_NAME     — Postgres database name
#   LOKI_URL          — Loki push endpoint, e.g. http://loki.loki.svc.cluster.local:3100
#   GRPC_URL          — gRPC service address, e.g. etri-llm-api-service.llm-evaluation.svc.cluster.local:9090
#
# This is a TEMPLATE. Do NOT commit real credentials.
---
apiVersion: v1
kind: Secret
metadata:
  name: etri-llm-backend
  namespace: llm-evaluation
  labels:
    app.kubernetes.io/managed-by: kubectl
    app.kubernetes.io/name: etri-llm-backend
    etri/secret-type: app-config
type: Opaque
stringData:
  PORT: "9999"
  NODE_ENV: "production"
  GRPC_IP: ${GRPC_URL}
  GRPC_CLIENT_NAME: "EXAM_PACKAGE"
  DATABASE_HOST: ${DATABASE_HOST}
  DATABASE_PORT: ${DATABASE_PORT}
  DATABASE_USER: ${DATABASE_USER}
  DATABASE_PASSWORD: ${DATABASE_PASSWORD}
  DATABASE_NAME: ${DATABASE_NAME}
  LOKI_URL: ${LOKI_URL}
