# Apply via: ./scripts/02_sync_ssh_and_credentials.sh after sourcing .env
#
# This is a TEMPLATE. Do NOT commit real credentials.
# The .dockerconfigjson value is a base64-encoded JSON object of the form:
#   {"auths":{"https://index.docker.io/v1/":{"auth":"<base64(user:token)>"}}}
#
# To apply manually:
#   export STRINGDATA_DOCKERCONFIGJSON="$(cat ~/.docker/config.json | base64 -w0)"
#   envsubst < k8s/secrets/dockerhub-pull-secret.yaml.template | kubectl apply -f -
---
apiVersion: v1
kind: Secret
metadata:
  name: image-pull-secret
  namespace: llm-evaluation
  labels:
    app.kubernetes.io/managed-by: kubectl
    etri/secret-type: registry
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: ${STRINGDATA_DOCKERCONFIGJSON}
