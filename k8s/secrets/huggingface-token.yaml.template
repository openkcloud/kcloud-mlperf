# HuggingFace API token secret template.
#
# Apply via envsubst after sourcing .env:
#   source config/.env
#   envsubst < k8s/secrets/huggingface-token.yaml.template | kubectl apply -f -
#
# Required env var:
#   HF_TOKEN  — HuggingFace access token with read access to gated models
#               (meta-llama/Llama-3.1-8B-Instruct requires HF approval).
#
# This is a TEMPLATE. Do NOT commit real tokens.
---
apiVersion: v1
kind: Secret
metadata:
  name: huggingface-token
  namespace: llm-bench
  labels:
    app.kubernetes.io/managed-by: kubectl
    etri/secret-type: model-registry
type: Opaque
stringData:
  HF_TOKEN: ${HF_TOKEN}
