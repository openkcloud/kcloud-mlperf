# TT100 (Time-to-100-output-tokens) NPU Benchmark Job — PRIMARY OBJECTIVE.
#
# Target: node4 (FuriosaAI RNGD NPU, 10.254.202.114)
# Model:  meta-llama/Llama-3.1-8B-Instruct (FP8)
# KPI:    mean time-to-100-output-tokens < 1.1 seconds (see config/cluster.yaml targets.primary)
#
# Measurement: 5 warmup runs, 30 measured runs, 100 output tokens per run.
# Outputs (written to results PVC):
#   results/${RUN_ID}/tt100/tt100_raw.jsonl   — per-run timing records
#   results/${RUN_ID}/tt100/tt100_summary.csv — aggregated statistics
#
# The tt100_runner.py script is delivered by the BENCHMARKS lane to:
#   results/${RUN_ID}/tt100_runner.py
# This Job references it from the results PVC mount. Do not block on its
# pre-existence — the Job will fail cleanly if the script is absent.
#
# Apply via envsubst:
#   envsubst < k8s/benchmark-jobs/tt100-npu-job.yaml.template | kubectl apply -f -
#
# Required env vars:
#   RUN_ID   — unique run identifier, e.g. 20260428-072038-a612a54
---
apiVersion: batch/v1
kind: Job
metadata:
  name: tt100-npu-${RUN_ID}
  namespace: llm-bench
  labels:
    app.kubernetes.io/name: tt100-npu-job
    app.kubernetes.io/managed-by: kubectl
    etri.run-id: "${RUN_ID}"
    etri.benchmark: tt100
    etri.model: llama-3.1-8b-instruct
    etri.device: rngd
    etri.precision: fp8
    etri.scenario: latency
spec:
  backoffLimit: 0
  ttlSecondsAfterFinished: 86400
  template:
    metadata:
      labels:
        app.kubernetes.io/name: tt100-npu-job
        etri.run-id: "${RUN_ID}"
        etri.benchmark: tt100
        etri.device: rngd
        etri.precision: fp8
    spec:
      restartPolicy: Never
      # Schedule exclusively on node4 (RNGD NPU node)
      nodeSelector:
        npu-model: rngd
      tolerations:
        - key: furiosa.ai/rngd
          operator: Exists
          effect: NoSchedule
      imagePullSecrets:
        - name: image-pull-secret
      initContainers:
        - name: wait-for-runner-script
          image: busybox:1.36
          imagePullPolicy: IfNotPresent
          command:
            - /bin/sh
            - -c
            - |
              SCRIPT=/mnt/results/${RUN_ID}/tt100_runner.py
              echo "Waiting for ${SCRIPT} ..."
              timeout=120
              elapsed=0
              while [ ! -f "${SCRIPT}" ]; do
                if [ "${elapsed}" -ge "${timeout}" ]; then
                  echo "ERROR: tt100_runner.py not found after ${timeout}s. Ensure BENCHMARKS lane has run."
                  exit 1
                fi
                sleep 5
                elapsed=$((elapsed + 5))
              done
              echo "Found ${SCRIPT}. Proceeding."
          env:
            - name: RUN_ID
              value: "${RUN_ID}"
          volumeMounts:
            - name: results-volume
              mountPath: /mnt/results
      containers:
        - name: tt100-runner
          image: furiosaai/furiosa-llm:latest
          imagePullPolicy: IfNotPresent
          env:
            - name: RUN_ID
              value: "${RUN_ID}"
            - name: MODEL_ID
              value: "meta-llama/Llama-3.1-8B-Instruct"
            - name: PRECISION
              value: "fp8"
            - name: WARMUP_RUNS
              value: "5"
            - name: MEASURED_RUNS
              value: "30"
            - name: OUTPUT_TOKENS
              value: "100"
            - name: OUTPUT_DIR
              value: "/mnt/results/${RUN_ID}/tt100"
            - name: HF_TOKEN
              valueFrom:
                secretKeyRef:
                  name: huggingface-token
                  key: HF_TOKEN
          command:
            - /bin/bash
            - -c
            - |
              set -euo pipefail
              mkdir -p "${OUTPUT_DIR}"
              echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] Starting TT100 benchmark"
              echo "  Model:         ${MODEL_ID}"
              echo "  Precision:     ${PRECISION}"
              echo "  Warmup runs:   ${WARMUP_RUNS}"
              echo "  Measured runs: ${MEASURED_RUNS}"
              echo "  Output tokens: ${OUTPUT_TOKENS}"
              echo "  Output dir:    ${OUTPUT_DIR}"
              python3 /mnt/results/${RUN_ID}/tt100_runner.py \
                --model-id "${MODEL_ID}" \
                --precision "${PRECISION}" \
                --warmup-runs "${WARMUP_RUNS}" \
                --measured-runs "${MEASURED_RUNS}" \
                --output-tokens "${OUTPUT_TOKENS}" \
                --output-raw "${OUTPUT_DIR}/tt100_raw.jsonl" \
                --output-summary "${OUTPUT_DIR}/tt100_summary.csv"
              echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] TT100 benchmark complete"
          resources:
            requests:
              furiosa.ai/rngd: "1"
              cpu: "4"
              memory: 32Gi
            limits:
              furiosa.ai/rngd: "1"
              cpu: "4"
              memory: 32Gi
          volumeMounts:
            - name: model-volume
              mountPath: /mnt/models
              readOnly: true
            - name: dataset-volume
              mountPath: /mnt/datasets
              readOnly: true
            - name: results-volume
              mountPath: /mnt/results
      volumes:
        - name: model-volume
          persistentVolumeClaim:
            claimName: model-nfs-pvc
        - name: dataset-volume
          persistentVolumeClaim:
            claimName: dataset-nfs-pvc
        - name: results-volume
          persistentVolumeClaim:
            claimName: results-nfs-pvc
