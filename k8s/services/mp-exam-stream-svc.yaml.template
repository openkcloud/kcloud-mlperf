# SSE stream service sanity-check template for etri-llm-backend.
#
# DRIFT CHECK: The helm chart's etri-llm-backend Service
#   (kubernetes/app-chart/templates/etri-llm-backend/service.yaml)
# exposes port 9999/TCP as a NodePort (nodePort: 30980).
# That is the production-canonical Service definition.
#
# This file documents the *desired shape* of the ClusterIP facet for
# in-cluster SSE consumers (e.g. the k8s-api sidecar calling /stream).
# If you need a separate ClusterIP for in-cluster access without NodePort
# exposure, apply this template. Otherwise the helm chart Service already
# covers this via its ClusterIP allocation (every NodePort Service also
# gets a ClusterIP).
#
# CONCLUSION: No drift detected. The helm Service already provides ClusterIP
# on port 9999. This template is a no-op in production but documents the
# intended shape for operators and GitOps audits.
#
# Apply (only if a dedicated ClusterIP Service is needed alongside the helm NodePort):
#   envsubst < k8s/services/mp-exam-stream-svc.yaml.template | kubectl apply -f -
#
# Required env vars:
#   NAMESPACE — target namespace, default: llm-evaluation
---
apiVersion: v1
kind: Service
metadata:
  name: etri-llm-backend-stream
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/name: etri-llm-backend
    app.kubernetes.io/component: sse-stream
    app.kubernetes.io/managed-by: kubectl
  annotations:
    etri/note: >
      Companion ClusterIP for in-cluster SSE consumers. The helm chart's
      etri-llm-backend-service (NodePort 30980) already allocates a ClusterIP
      on the same port. Only deploy this if a named in-cluster alias is
      operationally required.
spec:
  type: ClusterIP
  selector:
    app: etri-llm-backend
  ports:
    - name: sse-stream
      port: 9999
      targetPort: 9999
      protocol: TCP
