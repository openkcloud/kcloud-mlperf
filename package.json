{
  "name": "llm-exam-solution",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n \"SERVER,WEB\" -c \"yellow,cyan\" \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "npm --prefix ./server run start:dev",
    "dev:web": "npm --prefix ./web run dev",
    "docker-dev:compose-up": "sudo docker compose -f docker-compose.dev.yml up --build",
    "docker-dev:compose-down": "sudo docker compose -f docker-compose.dev.yml down"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}