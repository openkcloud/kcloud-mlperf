# In production the frontend nginx ConfigMap proxies /api/* and bare-prefix
# backend paths to the backend service same-origin. axios must use relative
# URLs. Leave this empty — the source default does the right thing.
VITE__APP_API_BASE_URL=

# GPU realtime Prometheus dashboard (used by gpu-realtime page + MLPerf + MMLU pages).
# Prometheus exposed via NodePort 30900 on every cluster node.
# Iframe loads expression browser; install Grafana with this as datasource for richer dashboards.
VITE__APP_GPU_PROMETHEUS_URL=http://10.254.177.41:30900/graph?g0.expr=sum%28rate%28DCGM_FI_DEV_GPU_UTIL%5B5m%5D%29%29%20by%20%28instance%29&g0.tab=0&g0.range_input=15m
