# These are some examples of commonly ignored file patterns.
# You should customize this list as applicable to your project.
# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/
dist/

# JetBrains IDE
.idea/

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv


# OMC session state — ephemeral
.omc/state/
.omc/autopilot/
.omc/notepad.md
.omc/research/

# Ansible retry files
*.retry

# Local kubeconfig (DO NOT COMMIT)
kubeconfig/admin.conf
kubeconfig/config

# kubectl/helm cache
.kube/cache/

# OMC session state at any depth (ephemeral, plus subagent transcripts that may include secrets)
**/.omc/state/
**/.omc/autopilot/
**/.omc/notepad.md
**/.omc/research/

# Kubeconfig at any depth (DO NOT COMMIT — contains cluster admin certs)
**/kubeconfig/admin.conf
**/kubeconfig/config

# Generic kubeconfig
*.kubeconfig

# Mission hardening pass — ephemeral
logs/
results/
backups/
*.log
.env
config/.env
node_modules/

# Scrubbed kubespray paths
kubespray/inventory/etri/credentials/
